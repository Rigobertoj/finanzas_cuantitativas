% Oxford-inspired color theme for the local Gemini poster theme.
\ProvidesPackage{beamercolorthemeox}[2026/04/20 Local Oxford color theme]

\RequirePackage{xcolor}

\definecolor{OxfordBlue}{RGB}{4,30,66}
\definecolor{OxfordBlueLight}{RGB}{161,178,195}
\definecolor{OxfordGold}{RGB}{166,137,79}
\definecolor{OxfordStone}{RGB}{245,246,248}
\definecolor{OxfordText}{RGB}{34,40,49}
\definecolor{OxfordAlert}{RGB}{120,60,32}

\setbeamercolor{normal text}{fg=OxfordText,bg=white}
\setbeamercolor{heading}{fg=OxfordBlue}

\setbeamercolor{headline}{fg=white,bg=OxfordBlue}
\setbeamercolor{headline title}{fg=white}
\setbeamercolor{headline author}{fg=white}
\setbeamercolor{headline institute}{fg=OxfordBlueLight}
\setbeamercolor{headline rule}{bg=OxfordGold}

\setbeamercolor{block title}{fg=white,bg=OxfordBlue}
\setbeamercolor{block separator}{bg=OxfordGold}
\setbeamercolor{block body}{fg=OxfordText,bg=OxfordStone}

\setbeamercolor{block title alerted}{fg=white,bg=OxfordAlert}
\setbeamercolor{block separator alerted}{bg=OxfordGold}
\setbeamercolor{block body alerted}{fg=OxfordText,bg=white}

\setbeamercolor{block title example}{fg=white,bg=OxfordGold}
\setbeamercolor{block separator example}{bg=OxfordBlue}
\setbeamercolor{block body example}{fg=OxfordText,bg=white}

\setbeamercolor{caption name}{fg=OxfordBlue}
\setbeamercolor{footline}{fg=white,bg=OxfordBlue}
