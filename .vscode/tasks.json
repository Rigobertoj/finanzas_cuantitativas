{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Render current TeX note",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/render_tex.sh",
      "args": [
        "--publish-parent",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
